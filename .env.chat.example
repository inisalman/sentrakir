# Chat AI Support - Environment Variables

# Google Gemini API Key
# Dapatkan dari: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Chat configuration
VITE_CHAT_ENABLED=true
VITE_CHAT_AUTO_CLEANUP_DAYS=30
VITE_CHAT_MAX_HISTORY=50

# Optional: Debug mode
VITE_CHAT_DEBUG=false
